# Supabase credentials
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Owner email (fast auth gate — baked into build)
VITE_OWNER_EMAIL=your-email@example.com

# Server-side Supabase (for cron jobs)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
BRIEFING_USER_ID=your-supabase-user-uuid
CRON_SECRET=your-cron-secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Notifications (optional — defaults to VITE_OWNER_EMAIL)
NOTIFICATION_EMAIL=

# Anthropic (for briefing + auto-complete)
ANTHROPIC_API_KEY=

# ─── New Integrations ───────────────────────────────────────────────────────

# Weather (OpenWeatherMap free tier — 1000 calls/day)
OPENWEATHERMAP_API_KEY=
WEATHER_LAT=40.2338
WEATHER_LON=-111.6585

# GitHub (fine-grained personal access token, read-only)
GITHUB_TOKEN=

# News (NewsAPI.org free tier — 100 requests/day)
NEWS_API_KEY=

# Notion (internal integration token)
NOTION_API_KEY=
NOTION_DATABASE_IDS=db-id-1,db-id-2

# Readwise (from readwise.io/access_token)
READWISE_ACCESS_TOKEN=

# OpenAI (for embeddings only — very cheap, ~$0.01/month)
OPENAI_API_KEY=
